# Native Land territories use full URIs: <https://native-land.ca/maps/territories/{slug}>

# ============================================================
# Dataset Metadata and Attribution
# ============================================================

canadageo:dataset a dcat:Dataset ;
    dcterms:title "The Evolving Geography of Canada (1667-2001): A CIDOC-CRM Knowledge Graph"@en ;
    dcterms:description "A linked open data representation of European/settler territorial assertions over Indigenous lands in what is now Canada, modeled in CIDOC-CRM. Indigenous territory data is referenced by URI from Native Land Digital; boundary geometries are not stored in this dataset."@en ;
    dcterms:created "2026-03-30"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by-nc/4.0/> ;
    dcterms:source canadageo:source-native-land-digital ;
    dcterms:source canadageo:source-territorial-evolution ;
    dcterms:source <http://www.wikidata.org/> .

# --------------------------------------------------------
# Native Land Digital Attribution
# Indigenous territory references in this dataset use URIs
# from Native Land Digital (https://native-land.ca/).
# Native Land Digital is an Indigenous-led educational
# platform. This dataset references Indigenous territories
# by URI only — no NLD boundary data is stored or
# redistributed. All Indigenous territory data remains
# under Indigenous governance per NLD's Data Sovereignty
# Treaty (https://api-docs.native-land.ca/data-sovereignty-treaty).
# For visualization, use the NLD API directly:
# https://api-docs.native-land.ca/
# --------------------------------------------------------

canadageo:source-native-land-digital a foaf:Organization ;
    rdfs:label "Native Land Digital"@en ;
    foaf:homepage <https://native-land.ca/> ;
    dcterms:description "An Indigenous-led non-profit organization entrusted with the stewardship of data from Indigenous communities worldwide. Indigenous communities are the rightful stewards of their territorial data."@en ;
    rdfs:seeAlso <https://api-docs.native-land.ca/data-sovereignty-treaty> .

canadageo:source-territorial-evolution a dcat:Dataset ;
    rdfs:label "Territorial Evolution, 1670-2001"@en ;
    dcterms:creator "Nicholson, Norman L.; Whebell, Charles F. J.; Galois, Robert; Stavely, Michael"@en ;
    dcterms:identifier <https://doi.org/10.5683/SP2/IQ7E0X> ;
    dcterms:publisher "Borealis"@en ;
    dcterms:date "2020"^^xsd:gYear ;
    dcterms:description "Shapefiles for two interactive maps from the Historical Atlas of Canada Online Learning Project: Boundary Changes 1670-2001 and Newfoundland Joins Confederation 1949."@en ;
    dcterms:license <https://creativecommons.org/licenses/by-nc/4.0/> ;
    dcterms:bibliographicCitation "Nicholson, Norman L.; Whebell, Charles F. J.; Galois, Robert; Stavely, Michael, 2020, \"Territorial Evolution, 1670-2001\", https://doi.org/10.5683/SP2/IQ7E0X, Borealis, V1"@en .

# ============================================================
# Custom Properties
# ============================================================

canadageo:asserted_jurisdiction_over a rdf:Property ;
    rdfs:label "asserted jurisdiction over"@en ;
    rdfs:comment "Links a colonial/political E7 Activity (assertion of jurisdiction) to an Indigenous E53 Place whose territory it spatially overlaps with. This property records the colonial power's assertion, not a transfer of sovereignty. Many Indigenous territories were never legally ceded, and effective Indigenous governance persisted long after European assertions."@en ;
    rdfs:domain crm:E7_Activity ;
    rdfs:range crm:E53_Place .

canadageo:formally_recognized_sovereignty_of a rdf:Property ;
    rdfs:label "formally recognized sovereignty of"@en ;
    rdfs:comment "Links an act of formal recognition to Indigenous E53 Places whose sovereignty was acknowledged within a European legal framework. These rights pre-exist the recognition — the act does not grant them. In practice, there were considerable breaches of these formal commitments."@en ;
    rdfs:domain crm:E7_Activity ;
    rdfs:range crm:E53_Place .

# ============================================================
# E55 Types (classification vocabulary)
# ============================================================

canadageo:type-assertion-of-jurisdiction a crm:E55_Type, skos:Concept ;
    rdfs:label "Assertion of Jurisdiction"@en ;
    skos:prefLabel "Assertion of Jurisdiction"@en ;
    rdfs:comment "A unilateral assertion of political or administrative jurisdiction over territory. Does not imply consent of existing inhabitants or legal cession of Indigenous sovereignty."@en .

canadageo:type-inter-european-treaty-assertion a crm:E55_Type, skos:Concept ;
    rdfs:label "Inter-European Treaty Assertion"@en ;
    skos:prefLabel "Inter-European Treaty Assertion"@en ;
    rdfs:comment "Jurisdiction asserted on the basis of a treaty between European powers. Indigenous nations were not party to these agreements."@en .

canadageo:type-commercial-monopoly-grant a crm:E55_Type, skos:Concept ;
    rdfs:label "Commercial Monopoly Grant"@en ;
    skos:prefLabel "Commercial Monopoly Grant"@en ;
    rdfs:comment "Jurisdiction exercised under a commercial charter or monopoly grant (e.g., Hudson's Bay Company). Control was primarily economic, not administrative in many regions."@en .

canadageo:type-legislative-assertion a crm:E55_Type, skos:Concept ;
    rdfs:label "Legislative Assertion"@en ;
    skos:prefLabel "Legislative Assertion"@en ;
    rdfs:comment "Jurisdiction asserted through unilateral legislation by a settler government (e.g., Acts of Parliament, Orders in Council)."@en .

canadageo:type-administrative-jurisdiction a crm:E55_Type, skos:Concept ;
    rdfs:label "Administrative Jurisdiction"@en ;
    skos:prefLabel "Administrative Jurisdiction"@en ;
    rdfs:comment "Ongoing administrative governance of a defined territory (e.g., a province or territory within Confederation)."@en .

canadageo:type-disputed-assertion a crm:E55_Type, skos:Concept ;
    rdfs:label "Disputed Assertion"@en ;
    skos:prefLabel "Disputed Assertion"@en ;
    rdfs:comment "Territory where multiple European/settler powers asserted overlapping and contested jurisdiction."@en .

canadageo:type-formal-recognition-of-indigenous-sovereignty a crm:E55_Type, skos:Concept ;
    rdfs:label "Formal Recognition of Indigenous Sovereignty"@en ;
    skos:prefLabel "Formal Recognition of Indigenous Sovereignty"@en ;
    rdfs:comment "Formal legal recognition by a European/settler power of Indigenous sovereignty over territory. Does not grant these rights — they pre-exist the recognition. The Royal Proclamation of 1763 is a key example. In practice, there were considerable breaches of these formal commitments on the ground."@en .

canadageo:type-province a crm:E55_Type, skos:Concept ;
    rdfs:label "Province"@en ;
    skos:prefLabel "Province"@en ;
    rdfs:comment "Canadian province."@en .

canadageo:type-territory a crm:E55_Type, skos:Concept ;
    rdfs:label "Territory"@en ;
    skos:prefLabel "Territory"@en ;
    rdfs:comment "Canadian territory."@en .

canadageo:type-district a crm:E55_Type, skos:Concept ;
    rdfs:label "District"@en ;
    skos:prefLabel "District"@en ;
    rdfs:comment "Administrative district within a territory."@en .

canadageo:type-indigenous-territory a crm:E55_Type, skos:Concept ;
    rdfs:label "Indigenous Territory"@en ;
    skos:prefLabel "Indigenous Territory"@en ;
    rdfs:comment "Territory of an Indigenous people. These territories are enduring — they are not contingent on European recognition and many have never been legally ceded."@en .

canadageo:type-sovereign-state a crm:E55_Type, skos:Concept ;
    rdfs:label "Sovereign State"@en ;
    skos:prefLabel "Sovereign State"@en ;
    rdfs:comment "A sovereign political entity."@en .

canadageo:type-commercial-sovereign a crm:E55_Type, skos:Concept ;
    rdfs:label "Commercial Sovereign"@en ;
    skos:prefLabel "Commercial Sovereign"@en ;
    rdfs:comment "A commercial entity exercising territorial control under charter or grant."@en .

canadageo:type-inter-european-treaty a crm:E55_Type, skos:Concept ;
    rdfs:label "Inter-European Treaty"@en ;
    skos:prefLabel "Inter-European Treaty"@en ;
    rdfs:comment "A formal agreement between European powers regarding territorial boundaries. Indigenous nations were generally not consulted or party to these agreements."@en .

canadageo:type-act-of-parliament a crm:E55_Type, skos:Concept ;
    rdfs:label "Act of Parliament"@en ;
    skos:prefLabel "Act of Parliament"@en ;
    rdfs:comment "Legislation enacted by a parliament, often unilaterally asserting jurisdiction over Indigenous territories."@en .

canadageo:type-order-in-council a crm:E55_Type, skos:Concept ;
    rdfs:label "Order in Council"@en ;
    skos:prefLabel "Order in Council"@en ;
    rdfs:comment "Executive order by a privy council or governor general."@en .

canadageo:type-boundary-decision a crm:E55_Type, skos:Concept ;
    rdfs:label "Boundary Decision"@en ;
    skos:prefLabel "Boundary Decision"@en ;
    rdfs:comment "A judicial or diplomatic boundary determination."@en .

canadageo:type-purchase-or-cession a crm:E55_Type, skos:Concept ;
    rdfs:label "Purchase or Cession"@en ;
    skos:prefLabel "Purchase or Cession"@en ;
    rdfs:comment "A transfer of claimed jurisdiction between European/settler powers (e.g., Alaska Purchase, Louisiana Purchase). These transfers concerned claims between settler powers and did not involve Indigenous consent."@en .

